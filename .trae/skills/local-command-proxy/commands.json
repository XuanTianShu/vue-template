{
  "node_core": {
    "node_version": {
      "command_line": "node -v",
      "description": "查看Node.js版本"
    },
    "npm_version": {
      "command_line": "npm -v",
      "description": "查看npm版本"
    },
    "npm_install": {
      "command_line": "npm install",
      "description": "npm安装依赖"
    },
    "yarn_version": {
      "command_line": "yarn -v",
      "description": "查看yarn版本"
    },
    "pnpm_version": {
      "command_line": "pnpm -v",
      "description": "查看pnpm版本"
    },
    "pnpm_install": {
      "command_line": "pnpm install",
      "description": "pnpm安装项目依赖"
    },
    "pnpm_update": {
      "command_line": "pnpm update",
      "description": "pnpm更新所有依赖"
    },
    "pnpm_add": {
      "command_line": "pnpm add",
      "description": "pnpm安装生产依赖"
    },
    "pnpm_add_dev": {
      "command_line": "pnpm add -D",
      "description": "pnpm安装开发依赖"
    }
  },
  "frontend_dev": {
    "dev": {
      "command_line": "pnpm dev",
      "description": "启动开发服务器"
    },
    "start": {
      "command_line": "pnpm start",
      "description": "启动生产服务器"
    },
    "build": {
      "command_line": "pnpm run build",
      "description": "构建生产版本"
    },
    "preview": {
      "command_line": "pnpm run preview",
      "description": "预览生产构建"
    },
    "lint": {
      "command_line": "pnpm run lint",
      "description": "执行ESLint代码检查"
    },
    "lint_fix": {
      "command_line": "pnpm run lint --fix",
      "description": "自动修复ESLint错误"
    },
    "format": {
      "command_line": "pnpm run format",
      "description": "执行Prettier代码格式化"
    },
    "type_check": {
      "command_line": "pnpm run type-check",
      "description": "执行TypeScript类型检查"
    },
    "test": {
      "command_line": "pnpm run test",
      "description": "运行单元测试"
    },
    "test_unit": {
      "command_line": "pnpm run test:unit",
      "description": "运行单元测试(vitest模式)"
    },
    "test_e2e": {
      "command_line": "pnpm run test:e2e",
      "description": "运行E2E端到端测试"
    },
    "test_coverage": {
      "command_line": "pnpm run test --coverage",
      "description": "运行测试并生成覆盖率报告"
    }
  },
  "vue_specific": {
    "vue_create": {
      "command_line": "pnpm create vite@latest . -- --template vue",
      "description": "创建Vue3项目（无TS）"
    },
    "vue_create_ts": {
      "command_line": "pnpm create vite@latest . -- --template vue-ts",
      "description": "创建Vue3+TS项目"
    },
    "vue_add_router": {
      "command_line": "pnpm add vue-router@4",
      "description": "安装Vue Router 4"
    },
    "vue_add_pinia": {
      "command_line": "pnpm add pinia",
      "description": "安装Pinia状态管理"
    },
    "vue_add_element_plus": {
      "command_line": "pnpm add element-plus",
      "description": "安装Element Plus UI库"
    },
    "vue_add_naive_ui": {
      "command_line": "pnpm add naive-ui",
      "description": "安装Naive UI组件库"
    },
    "vue_devtools": {
      "command_line": "pnpm add -D vue-devtools",
      "description": "安装Vue DevTools开发工具"
    }
  },
  "react_specific": {
    "react_create": {
      "command_line": "pnpm create vite@latest . -- --template react",
      "description": "创建React项目"
    },
    "react_create_ts": {
      "command_line": "pnpm create vite@latest . -- --template react-ts",
      "description": "创建React+TS项目"
    },
    "react_add_router": {
      "command_line": "pnpm add react-router-dom",
      "description": "安装React Router DOM"
    },
    "react_add_redux": {
      "command_line": "pnpm add @reduxjs/toolkit react-redux",
      "description": "安装Redux Toolkit"
    }
  },
  "build_tools": {
    "vite_info": {
      "command_line": "pnpx vite info",
      "description": "查看Vite环境信息"
    },
    "webpack_version": {
      "command_line": "npx webpack --version",
      "description": "查看webpack版本"
    },
    "rollup_version": {
      "command_line": "npx rollup --version",
      "description": "查看rollup版本"
    }
  },
  "css_tools": {
    "add_tailwind": {
      "command_line": "pnpm add -D tailwindcss postcss autoprefixer && npx tailwindcss init -p",
      "description": "安装并初始化Tailwind CSS"
    },
    "add_unocss": {
      "command_line": "pnpm add -D unocss",
      "description": "安装UnoCSS原子化CSS框架"
    },
    "add_sass": {
      "command_line": "pnpm add -D sass",
      "description": "安装Sass预处理器"
    },
    "add_less": {
      "command_line": "pnpm add -D less",
      "description": "安装Less预处理器"
    }
  },
  "git": {
    "git_status": {
      "command_line": "git status",
      "description": "查看Git状态"
    },
    "git_log": {
      "command_line": "git log --oneline -n 10",
      "description": "查看最近10条Git提交"
    },
    "git_branch": {
      "command_line": "git branch -a",
      "description": "查看所有分支"
    },
    "git_fetch": {
      "command_line": "git fetch --all",
      "description": "拉取所有远程更新"
    },
    "git_pull": {
      "command_line": "git pull",
      "description": "拉取当前分支更新"
    }
  },
  "system_check": {
    "npm_list_g": {
      "command_line": "npm list -g --depth 0",
      "description": "查看全局安装的npm包"
    },
    "pnpm_list_g": {
      "command_line": "pnpm list -g --depth 0",
      "description": "查看全局安装的pnpm包"
    },
    "check_port_3000": {
      "command_line": "netstat -ano | findstr :3000",
      "description": "检查3000端口占用"
    },
    "check_port_5173": {
      "command_line": "netstat -ano | findstr :5173",
      "description": "检查Vite默认端口占用"
    }
  }
}